rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userDocData(uid) {
      return get(userPath(uid)).data;
    }

    function isAdmin() {
      return signedIn()
        && exists(userPath(request.auth.uid))
        && userDocData(request.auth.uid).role == "admin";
    }

    function isEmploye() {
      return signedIn()
        && exists(userPath(request.auth.uid))
        && userDocData(request.auth.uid).role == "employe";
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());

      // Comptes créés uniquement par l'admin (Cloud Functions + Admin SDK).
      allow create: if false;

      // Admin can update any user doc.
      // Employee can update only their profile fields (not role/email/createdAt).
      allow update: if isAdmin()
        || (
          signedIn()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "nom",
            "matricule",
            "telephone",
            "departement",
            "poste",
            "cin",
            "adresse",
            "dateNaissance",
            "dateEmbauche",
            "photoURL"
          ])
          && (!("photoURL" in request.resource.data) || request.resource.data.photoURL is string)
          && (!("email" in resource.data) || request.resource.data.email == resource.data.email)
          && (!("role" in resource.data) || request.resource.data.role == resource.data.role)
          && (!("createdAt" in resource.data) || request.resource.data.createdAt == resource.data.createdAt)
        );
      allow delete: if false;
    }

    match /pointages/{pointageId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /conges/{congeId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isEmploye()
        && request.resource.data.keys().hasOnly(["userId", "dateDebut", "dateFin", "type", "statut", "createdAt"])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.dateDebut is string
        && request.resource.data.dateFin is string
        && request.resource.data.type in ["annuel", "maladie", "exceptionnel"]
        && request.resource.data.statut == "en_attente"
        && request.resource.data.createdAt == request.time;

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["statut"])
        && request.resource.data.statut in ["en_attente", "valide", "refuse"];

      allow delete: if false;
    }

    // App settings (QR rotation, etc.) - admin only
    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /demandes_acces/{demandeId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "statut",
          "date_traitement",
          "traite_par",
          "userId"
        ])
        && request.resource.data.statut in ["en_attente", "approuvee", "refusee"];
      allow delete: if false;
    }

    match /demandes_reset_mdp/{demandeId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /parametres_entreprise/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // In-app notifications - employee can read their own notifications
    match /notifications/{notifId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      // Employé : marquer comme lue uniquement (read: false -> true)
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.read == false
        && request.resource.data.read == true
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.title == resource.data.title
        && request.resource.data.body == resource.data.body
        && request.resource.data.createdAt == resource.data.createdAt
        && (!("type" in resource.data) || request.resource.data.type == resource.data.type)
        && (!("actionHref" in resource.data) || request.resource.data.actionHref == resource.data.actionHref)
        && (!("qrLink" in resource.data) || request.resource.data.qrLink == resource.data.qrLink);
      allow delete: if false;
    }
  }
}
