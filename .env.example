# --- Firebase Web (client) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin (server API routes) — choisir UNE des options ---

# Option A (recommandée en local) : fichier JSON téléchargé depuis Firebase Console
# Copiez le fichier à la racine du projet sous le nom serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json

# Option B : JSON sur une seule ligne dans .env.local
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...",...}

# Option C : Realtime Database (non utilisée par TimeTrack Pro — Firestore uniquement)
# FIREBASE_DATABASE_URL=https://systempointage-88b6e-default-rtdb.europe-west1.firebasedatabase.app

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# --- QR dynamique (30 s) — optionnel si secret généré dans Firestore ---
POINTAGE_QR_SECRET=

# --- Géofence fallback (si parametres_entreprise/default absent) ---
ORG_LAT=
ORG_LON=
ORG_RADIUS_M=
NEXT_PUBLIC_ORG_LAT=
NEXT_PUBLIC_ORG_LON=
NEXT_PUBLIC_ORG_RADIUS_M=

# --- Email (recommandé : Resend — Outlook SMTP bloqué sur comptes récents) ---
# 1) Créez un compte gratuit sur https://resend.com → API Keys
RESEND_API_KEY=
EMAIL_FROM=TimeTrack Pro <onboarding@resend.dev>
ADMIN_NOTIFY_EMAIL=syspointage@outlook.com

# --- Email Outlook SMTP (souvent bloqué — ne fonctionne pas sur nouveaux comptes @outlook.com) ---
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=syspointage@outlook.com
# SMTP_PASS=mot_de_passe_application

# --- Cloud Functions (firebase functions:config ou .env functions) ---
# POINTAGE_QR_TOKEN=  # legacy weekly mode fallback
